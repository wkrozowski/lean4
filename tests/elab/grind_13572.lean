right : -1 * x1 + 1 ≤ 0 → -1 * x1 + x4 + 1 ≤ 0
h_10 : ¬x1 = 0 → x2 + -1 * x4 + -1 * (x1 * x3) = 0
h_11 : x1 + -1 * x2 + 1 ≤ 0
