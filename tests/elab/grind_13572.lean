#guard_msgs in
example : ∀ (x1 x2 x3 x4 x5 x6 x7 : Int),
  (0 ≤ 2 → True → 0 ≤ x2) →
    (0 < 2 → 0 ≤ x7 → 0 < x2) →
      0 < x3 ∧ x6 = x3 ∨ x3 ≤ 0 ∧ x6 = 0 →
        0 ≤ x5 →
          x6 ≤ x5 + 1 + 0 →
            x1 * (x5 + 1 + 0) > x2 →
              x5 + 1 = x6 →
                (x1 = 0 → x4 = x2) →
                  (x1 = 0 → x3 = 0) →
                    (0 < x1 → 0 ≤ x4 ∧ x4 < x1) →
                      (¬x1 = 0 → x2 = x1 * x3 + x4) → x1 < x2 → 0 ≤ x1 → x1 < x2 → 0 ≤ x1 → ¬False → False := by
  lia -verbose
